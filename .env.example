# Reemplaza los valores antes de usar
# Usa las URLs de tu base gestionada (Neon/Vercel Postgres). No uses localhost en producción.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"   # pooled
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require"     # direct (sin pool)

# NEXTAUTH
# Recomendado: un string aleatorio largo. Puedes generarlo con Node:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="pon_aqui_un_string_aleatorio_largo"
NEXTAUTH_URL="http://localhost:3000"  # en producción: https://tu-dominio.vercel.app

# ============= SIICAR LOCAL BRIDGE =============
# URL donde corre el servidor bridge SIICAR (en tu máquina local)
# Ejemplo: http://localhost:9500 (desarrollo)
# Ejemplo: https://abc123.ngrok.io (con ngrok)
SIICAR_LOCAL_URL="http://localhost:9500"

# Clave de autenticación para el bridge
SIICAR_LOCAL_KEY="your-siicar-api-key-here"

# ============= VERCEL CRON FUNCTIONS =============
# Clave secreta para validar que los crons vienen de Vercel
# Genera una cadena aleatoria fuerte
CRON_SECRET="your-random-cron-secret-change-this"

# ============= SIICAR (alternativo/legacy) =============
SIICAR_BASE_URL="https://api.siicar.local"
SIICAR_API_KEY="api_key_siicar"
 
# Seed ADMIN (opcional)
# Personaliza estas variables o elimínalas si no quieres crear el admin automáticamente en seed
SEED_ADMIN_EMAIL="anakingstorm@gmail.com"
SEED_ADMIN_PASSWORD="admin2225"
SEED_ADMIN_NAME="Administrador"
