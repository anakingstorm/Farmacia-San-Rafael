{
  "name": "farmacia-san-rafael",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/sync-db-if-needed.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate",
